  <xs:group name="G">
    <xs:sequence>
      <xs:element name="amount" type="t:Money"/>
    </xs:sequence>
  </xs:group>
  <xs:attributeGroup name="AG">
    <xs:attribute name="currency" type="t:Currency"/>
  </xs:attributeGroup>
</xs:schema>
