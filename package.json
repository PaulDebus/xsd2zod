{
  "name": "xsd-to-zod",
  "version": "0.1.0",
  "description": "Turn XSD schemas into type-safe Zod parsers for XML, with a metadata-driven runtime for parseXml/serializeXml round-trips.",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./validate": {
      "types": "./dist/validate.d.ts",
      "default": "./dist/validate.js"
    }
  },
  "bin": {
    "xsd-to-zod": "./dist/cli.js"
  },
  "scripts": {
    "pretest": "npm run build",
    "pretest:coverage": "npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build": "tsc -p tsconfig.build.json",
    "test:watch": "vitest",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PaulDebus/xsd-to-zod.git"
  },
  "keywords": [
    "xsd",
    "zod",
    "xml",
    "schema",
    "code-generation",
    "xml-parsing",
    "typescript",
    "validation"
  ],
  "author": "Paul Debus",
  "license": "GPL-3.0-only",
  "type": "module",
  "bugs": {
    "url": "https://github.com/PaulDebus/xsd-to-zod/issues"
  },
  "homepage": "https://github.com/PaulDebus/xsd-to-zod#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@nodable/base-output-builder": "^2.0.0",
    "@nodable/compact-builder": "^2.0.0",
    "@nodable/flexible-xml-parser": "^1.10.0",
    "iconv-lite": "^0.7.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "libxml2-wasm": "^0.7.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "libxml2-wasm": "^0.7.1"
  },
  "peerDependenciesMeta": {
    "libxml2-wasm": {
      "optional": true
    }
  },
  "types": "./dist/index.d.ts"
}
